            "confidence": "high",
            "usps_validated": false,
            "usps_match_code": ""
          }
        },
        "LLMJudgeTrajectory": {
          "expectedAgentBehavior": "The agent should parse the address components as provided (state AZ, ZIP 55555) and call the validate_address tool with those values. The USPS API will return null because the address is invalid. This null response is expected and correct behavior for a completely made-up address."
        }
      },
      "updatedAt": "2026-03-04T22:30:12.454Z"
    },
    {
